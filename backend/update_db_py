import sqlite3
import os

# Caminho para o seu banco de dados
BASE_DIR = os.path.dirname(os.path.abspath(__file__))
DB_PATH = os.path.join(BASE_DIR, "assets.db")

def atualizar_estrutura_banco():
    conn = sqlite3.connect(DB_PATH)
    cursor = conn.cursor()
    
    print(f"⚙️ Atualizando estrutura em: {DB_PATH}")
    
    # Adicionando as novas colunas uma por uma
    novas_colunas = [
        "ALTER TABLE assets ADD COLUMN codigo_oportunidade TEXT",
        "ALTER TABLE assets ADD COLUMN status TEXT DEFAULT 'pendente'",
        "ALTER TABLE assets ADD COLUMN data_formalizacao DATETIME",
        "ALTER TABLE assets ADD COLUMN email_signatario TEXT"
    ]
    
    for comando in novas_colunas:
        try:
            cursor.execute(comando)
            print(f"✅ Comando executado: {comando[:30]}...")
        except sqlite3.OperationalError as e:
            # Se a coluna já existir, ele apenas avisa e pula
            print(f"ℹ️ Coluna já existente ou erro: {e}")

    # Criando o índice para busca rápida pelo código da oportunidade
    try:
        cursor.execute("CREATE UNIQUE INDEX IF NOT EXISTS idx_assets_codigo_oportunidade ON assets (codigo_oportunidade)")
        print("✅ Índice de busca criado com sucesso.")
    except Exception as e:
        print(f"⚠️ Erro ao criar índice: {e}")

    conn.commit()
    conn.close()
    print("\n🚀 Banco de dados atualizado e pronto para a ZapSign.")

if __name__ == "__main__":
    atualizar_estrutura_banco()