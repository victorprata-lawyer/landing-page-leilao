{
  "rewrites": [
    {
      "source": "/mesa",
      "destination": "/mesa/index.html"
    },
    {
      "source": "/mesa/(.*)",
      "destination": "/mesa/$1"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/api",
      "destination": "/api/index.py"
    }
  ]
}